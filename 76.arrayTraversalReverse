import java.util.Scanner;

class Solution {

    public static void arrayTraversalReverse(int[] arr, int n) {
        for (int i = n - 1; i >= 0; i--) {
            System.out.print(arr[i]);

            if (i != 0) {
                System.out.print(" ");
            }
        }
    }

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Array ka size
        int n = sc.nextInt();

        // Array create
        int[] arr = new int[n];

        // Array input
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        // Method call
        arrayTraversalReverse(arr, n);
    }
}
