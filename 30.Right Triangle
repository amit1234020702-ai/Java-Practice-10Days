public class RightTriangle {
    public static void main(String[] args) {

        int n = 5;

        for (int i = 1; i <= n; i++) {     // Rows

            for (int j = 1; j <= i; j++) { // Stars
                System.out.print("* ");
            }

            System.out.println();
        }
    }
}
output
*
* *
* * *
* * * *
* * * * *
